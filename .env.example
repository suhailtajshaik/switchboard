# Switchboard configuration — copy to /opt/switchboard/.env, chmod 600.
# Every variable documented in docs/configuration.md.

# --- Brain (reference: Claude Agent SDK) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE
# BRAIN_BASE_URL=                 # optional: compatible gateway
# BRAIN_MODEL=                    # optional: choose a LOW-LATENCY model

# --- Control channel: Telegram (root of trust + approval channel) ---
TELEGRAM_BOT_TOKEN=REPLACE
TELEGRAM_OWNER_CHAT_ID=REPLACE

# --- Telephony: Twilio ---
TWILIO_ACCOUNT_SID=ACREPLACE
TWILIO_AUTH_TOKEN=REPLACE
TWILIO_NUMBER=+15550000000

# --- Identity ---
OWNER_NAME=Alex
OWNER_PHONE=+15550000001
WHITELIST_PHONES=                 # comma-separated E.164, optional

# --- Server ---
PUBLIC_DOMAIN=assistant.example.com
OWNER_TIMEZONE=America/New_York

# --- Voice / locale (optional) ---
# PERSONA_LANG=en                 # personas/<lang>/ overlay pack
# TTS_PROVIDER=                   # TTS provider hint for the telephony adapter
# TTS_VOICE=                      # specific TTS voice id
# DEFAULT_REGION=US               # region for numbers given without "+"

# --- Policy / safety ---
QUIET_HOURS_START=21
QUIET_HOURS_END=09
MAX_CALL_MINUTES=10
DAILY_MAX_OUTBOUND_CALLS=15
DAILY_MAX_SMS=30
ESCALATION_WAIT_MINUTES=5
APPROVAL_TIMEOUT_MINUTES=5        # sensitive-action out-of-band approval expiry
SMS_ENABLED=false                 # flip true after A2P 10DLC approval (US)
# DTMF_PIN=                       # optional keypad 2nd factor; never sole gate

# --- Inbound abuse limits + reliability ---
MAX_CONCURRENT_CALLS=2
INBOUND_PER_NUMBER_COOLDOWN_SECONDS=60
DAILY_INBOUND_MINUTES=120
BRAIN_RESPONSE_TIMEOUT_SECONDS=12
RELAY_NONCE_TTL_SECONDS=120
# BLOCKED_PREFIXES=               # extend the built-in emergency/premium list

# --- Operations ---
DAILY_MAX_SPEND_USD=5.0           # soft daily $ budget (telephony+LLM)
TRANSCRIPT_RETENTION_DAYS=90      # 0 = don't store transcripts
DRY_RUN=false                     # true = rehearse without real calls/SMS
# BACKUP_REMOTE=                  # rclone remote for backups — set on the
#                                 # backup cron line, not here (ops guide §6)
