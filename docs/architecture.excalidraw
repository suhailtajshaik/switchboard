  {
   "id": "panelA",
   "type": "rectangle",
   "x": 40,
   "y": 1130,
   "width": 600,
   "height": 470,
   "angle": 0,
   "strokeColor": "#1971c2",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": {
